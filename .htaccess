Options -Indexes

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

<FilesMatch "(^\.|\.sql$|\.env$|\.map$|\.lock$|package(-lock)?\.json$|tsconfig\.json$|vite\.config\.ts$|tailwind\.config\.js$|postcss\.config\.js$|README\.md$|Readme\.txt$|vanica-data-.*\.json$)">
  Require all denied
</FilesMatch>

RedirectMatch 403 ^/(node_modules|src|includes|dams/includes|\.git|\.qoder|\.vercel)(/|$)
